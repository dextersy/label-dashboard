RewriteEngine On

# SEO Configuration for Social Media Crawlers
# Detects social media crawlers and proxies them to API-generated SEO pages.
# Uses [P,L] (transparent reverse proxy via mod_proxy) instead of [R=302] redirect.
# A proxy is critical: many crawlers (including Linktree) do NOT follow cross-domain
# 302 redirects for OG tag fetching. With a proxy, the SEO HTML is served at the
# original URL — the crawler never sees a redirect.
#
# User-Agent list includes known patterns plus generic HTTP clients often used by
# link-preview services whose exact UA strings are not publicly documented.
# If a crawler is still missed, check Apache access logs for its UA and add it here.
#
# Requires: mod_proxy and mod_proxy_http enabled on Apache.
# For proxying to HTTPS targets, add "SSLProxyEngine On" to your Apache VirtualHost
# config (not here — it is a VHost-level directive and can 500 the site if put in .htaccess).

# Detect social media crawlers for ticket purchase pages
RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|slackbot|discordbot|applebot|googlebot|bingbot|linktree|linktr\.ee|preview|LinkPreview|previewbot|iframely|embedly|outbrain|Quora|Pinterestbot|vkShare|W3C_Validator|redditbot|Slurp|DuckDuckBot|YandexBot|Baiduspider|AhrefsBot|SemrushBot) [NC]
RewriteRule ^public/tickets/buy/([0-9]+)$ https://api.spindly.app:3001/api/public/seo/event-$1.html [P,L]

# Detect social media crawlers for public events listing page
RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|slackbot|discordbot|applebot|googlebot|bingbot|linktree|linktr\.ee|preview|LinkPreview|previewbot|iframely|embedly|outbrain|Quora|Pinterestbot|vkShare|W3C_Validator|redditbot|Slurp|DuckDuckBot|YandexBot|Baiduspider|AhrefsBot|SemrushBot) [NC]
RewriteRule ^public/events$ https://api.spindly.app:3001/api/public/seo/events-%{HTTP_HOST}.html [P,L]

# Detect social media crawlers for artist EPK pages
RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|slackbot|discordbot|applebot|googlebot|bingbot|linktree|linktr\.ee|preview|LinkPreview|previewbot|iframely|embedly|outbrain|Quora|Pinterestbot|vkShare|W3C_Validator|redditbot|Slurp|DuckDuckBot|YandexBot|Baiduspider|AhrefsBot|SemrushBot) [NC]
RewriteRule ^public/epk/([0-9]+)$ https://api.spindly.app:3001/api/public/seo/epk-$1.html [P,L]

# Backward compatibility for old ticket URLs
# Redirect /public/tickets/buy.php?id=<x> to /public/tickets/buy/<x>
RewriteCond %{REQUEST_URI} ^/public/tickets/buy\.php$
RewriteCond %{QUERY_STRING} ^id=([0-9]+)(&.*)?$
RewriteRule ^public/tickets/buy\.php$ /public/tickets/buy/%1? [R=301,L]

# Redirect /public/tickets/verify.php?id=<x> to /public/tickets/verify/<x>
RewriteCond %{REQUEST_URI} ^/public/tickets/verify\.php$
RewriteCond %{QUERY_STRING} ^id=([0-9]+)(&.*)?$
RewriteRule ^public/tickets/verify\.php$ /public/tickets/verify/%1? [R=301,L]

# Redirect /public/tickets/buy.php?id=<x>&ref=<code> to /public/tickets/buy/<x>?ref=<code>
RewriteCond %{REQUEST_URI} ^/public/tickets/buy\.php$
RewriteCond %{QUERY_STRING} ^id=([0-9]+)&ref=([^&]+)(&.*)?$
RewriteRule ^public/tickets/buy\.php$ /public/tickets/buy/%1?ref=%2 [R=301,L]

# Handle Angular Router (client-side routing)
# If the requested resource doesn't exist as a file or directory
# Serve the index.html file instead (except for API calls)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/api/
RewriteRule ^.*$ /index.html [L]

# Optional: Enable compression for better performance
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>

# Optional: Set cache headers for static assets
<IfModule mod_expires.c>
    ExpiresActive on
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType application/pdf "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# Security headers
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # XSS Protection
    Header always set X-XSS-Protection "1; mode=block"
    
    # Prevent MIME sniffing
    Header always set X-Content-Type-Options "nosniff"
    
    # HTTPS redirect (uncomment if using HTTPS)
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>