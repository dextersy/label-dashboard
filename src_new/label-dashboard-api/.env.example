# Database Configuration (Supabase PostgreSQL)
# Option 1: Individual connection parameters
DB_SERVER=db.your-project.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USER=postgres.your-project
DB_PASSWORD=your_password
DB_SSL=true

# Option 2: Connection string (takes precedence if set)
# DATABASE_URL=postgresql://postgres.your-project:your_password@db.your-project.supabase.co:5432/postgres

# JWT Secret
JWT_SECRET=your_jwt_secret_key

# SMTP Configuration
SMTP_HOST=email-smtp.ap-southeast-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# PayMongo Configuration
PAYMONGO_SECRET_KEY=sk_test_your_key

# Short.io Configuration
SHORT_IO_KEY=your_short_io_key
SHORT_IO_DOMAIN=melt.click

# AWS S3 Configuration
S3_BUCKET=dashboard-uploads-test
S3_BUCKET_MASTERS=dashboard-uploads-masters
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_REGION=ap-southeast-1

# Security Configuration
FAILED_LOGIN_LIMIT=3
LOCK_TIME_IN_SECONDS=120

# CSRF Protection & CORS Configuration
# Additional allowed origins for CORS (comma-separated)
# Primary origins are loaded from the Domain table (domains with status='Connected')
# Use this for development environments or additional origins
# Example: ALLOWED_ORIGINS=http://localhost:4200,https://dev.example.com
ALLOWED_ORIGINS=http://localhost:4200

# Frontend Configuration
FRONTEND_URL=http://localhost:4200
FRONTEND_IP=127.0.0.1

# SSH Configuration for SSL Management
SSH_KEY_PATH=~/.ssh/id_rsa
SSH_USER=
SSL_SCRIPT_PATH=~/add-ssl-domain.sh

# DNS Configuration
# Set CF_API_TOKEN + CF_ZONE_ID to use Cloudflare; leave blank to use Lightsail
CF_API_TOKEN=
CF_ZONE_ID=

# Lightsail DNS (legacy — only needed if not using Cloudflare)
# LIGHTSAIL_DOMAIN is also used by Cloudflare as the base domain (e.g. spindly.app)
LIGHTSAIL_DOMAIN=your_domain
LIGHTSAIL_ACCESS_KEY=your_lightsail_access_key
LIGHTSAIL_SECRET_KEY=your_lightsail_secret_key
LIGHTSAIL_REGION=us-east-1

# Server Configuration
PORT=3000
HTTP_PORT=3000
HTTPS_PORT=3001
# Public-facing base URL of this API server (used for OAuth callback URIs, etc.)
# For local dev without ngrok: leave unset (defaults to http://localhost:PORT)
# For local dev with ngrok:    set to your ngrok URL, e.g. https://abc123.ngrok-free.app
# For production:              set to your API domain, e.g. https://api.yourdomain.com:3001
SERVER_URL=

# Rate Limiting Configuration
# Authentication endpoints (login, password reset, etc.)
AUTH_RATE_WINDOW_MS=300000
AUTH_RATE_MAX_REQUESTS=5

# General API endpoints
API_RATE_WINDOW_MS=60000
API_RATE_MAX_REQUESTS=100

# File upload endpoints
UPLOAD_RATE_WINDOW_MS=300000
UPLOAD_RATE_MAX_REQUESTS=10

# Email sending endpoints
EMAIL_RATE_WINDOW_MS=3600000
EMAIL_RATE_MAX_REQUESTS=20

# Public API endpoints
PUBLIC_RATE_WINDOW_MS=60000
PUBLIC_RATE_MAX_REQUESTS=50

# Admin operation endpoints
ADMIN_RATE_WINDOW_MS=60000
ADMIN_RATE_MAX_REQUESTS=30

# Global rate limiting (fallback)
GLOBAL_RATE_WINDOW_MS=60000
GLOBAL_RATE_MAX_REQUESTS=200

# ============================================
# SYSTEM API CONFIGURATION
# ============================================
# Enable System API (REQUIRED in production for cross-brand access)
# Set to 'true' to enable system API endpoints
ENABLE_SYSTEM_API=true

# System Token Expiry
# How long system user tokens remain valid
# Examples: '1h', '30m', '2h'
# Default: '1h'
SYSTEM_TOKEN_EXPIRY=1h

# Optional: IP Whitelisting for System API
# Comma-separated list of IP addresses allowed to access system API
# Leave empty to allow all IPs (not recommended for production)
# Example: SYSTEM_API_ALLOWED_IPS=192.168.1.100,10.0.0.50,172.16.0.10
SYSTEM_API_ALLOWED_IPS=

# Admin Email (used for system notifications)
ADMIN_EMAIL=admin@yourdomain.com

# Spindly.app brand ID — used for lead inquiry emails (from name + admin recipients)
SPINDLY_BRAND_ID=

# Ticketing Portal (organizer self-signup parent brand)
TICKETING_PARENT_BRAND_ID=

# Ticketing frontend URL — used as the redirect target after Google OAuth.
# For local dev:   set to http://localhost:4201
# For production:  leave unset to use the parent brand's domain from the DB,
#                  or set explicitly if it differs from the DB domain.
TICKETING_FRONTEND_URL=

# Google OAuth (used for Google Sign-In on the ticketing organizer portal)
# Get these from Google Cloud Console → APIs & Services → Credentials
# Also add SERVER_URL/api/auth/ticketing/google/callback to the authorized redirect URIs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Payment Method Minimum Amounts (optional)
# If set, credit card and/or DOB payments are excluded for totals below these amounts.
# Leave unset (or empty) to impose no minimum.
MIN_AMOUNT_CARD=
MIN_AMOUNT_DOB=

# B-Sheet Publisher Info (Sync Licensing)
BSHEET_PUBLISHER_NAME=
BSHEET_PUBLISHER_PRO=
BSHEET_PUBLISHER_IPI=
BSHEET_PUBLISHER_PHONE=
BSHEET_PUBLISHER_EMAIL=

AUDIENCE_APP_URL=